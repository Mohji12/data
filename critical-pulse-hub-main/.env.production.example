# Production build (npm run build). Copy to .env.production before building.
# API + registration document URLs (files on krintixsample, not harishcriticalcareclasses.com).
VITE_API_URL=https://krintixsample.site
VITE_DOCUMENT_PUBLIC_BASE_URL=https://krintixsample.site
VITE_API_USE_PROXY=false
# Optional: only if old PHP-hosted document URLs are still needed in admin.
# VITE_LEGACY_UPLOAD_BASE_URL=https://harishcriticalcareclasses.com
