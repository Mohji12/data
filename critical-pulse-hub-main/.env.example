# Option A — remote API (e.g. krintixsample.site), UI on localhost:8080:
# VITE_API_USE_PROXY=false
# VITE_API_URL=https://krintixsample.site
#
# Option B — local FastAPI on :8000 via Vite proxy (needs uvicorn running):
# VITE_API_USE_PROXY=true
# VITE_API_URL=http://127.0.0.1:8000

VITE_API_USE_PROXY=false
VITE_API_URL=https://krintixsample.site

