# Recommended — remote API (krintixsample.site) via Vite proxy (no CORS issues on localhost:8080):
VITE_API_USE_PROXY=false
VITE_API_URL=https://krintixsample.site
#
# Local FastAPI on :8000 via proxy (needs uvicorn running):
# VITE_API_USE_PROXY=true
# VITE_API_URL=http://127.0.0.1:8000
#
# Direct browser → API (only if server CORS_ORIGINS includes http://localhost:8080):
# VITE_API_USE_PROXY=false
# VITE_API_URL=https://krintixsample.site
