# Local FastAPI (recommended) — browser :8080 → Vite proxy → http://127.0.0.1:8000
VITE_API_USE_PROXY=true
VITE_API_URL=http://127.0.0.1:8000

# Direct browser → API (only if CORS_ORIGINS includes http://localhost:8080 on the backend):
# VITE_API_USE_PROXY=false
# VITE_API_URL=http://127.0.0.1:8000

# Production:
# VITE_API_USE_PROXY=false
# VITE_API_URL=https://krintixsample.site
