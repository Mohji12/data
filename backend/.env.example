# Copy to `.env` in this folder (mock_test/backend). Values override defaults when the API starts.

# Set to false so email-only mock login does NOT require payment_status=Credit and approve=1.
# Use true in production to mirror the PHP site gates.
EMAIL_ONLY_LOGIN_STRICT=false

# Optional: after password login, rewrite users.password to PHP-outer hash (usually leave off).
# AUTH_SYNC_PASSWORD_ON_LOGIN=true

# Token settings for FastAPI protected routes.
# Use a long random secret in production.
API_TOKEN_SECRET=change-this-secret
API_TOKEN_TTL_HOURS=24

# Browser origins allowed to call this API (comma-separated, no trailing slashes).
CORS_ORIGINS=https://harishcriticalcareclasses.com,https://krintixsample.site,http://localhost:8080,http://127.0.0.1:8080

# Registration/payment gateway
PAYMENT_GATEWAY_NAME=razorpay
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Optional full URL to logo image in emails (default: {EMAIL_ASSET_BASE_URL}/hero/logo.png)
# EMAIL_LOGO_URL=https://harishcriticalcareclasses.com/hero/logo.png
# ZeptoMail (Zoho transactional): smtp.zeptomail.in or smtp.zeptomail.com, port 587 (TLS) or 465 (SSL).
# Username: emailapikey — Password: Send Mail token from Agent → SMTP/API tab (not dashboard login).
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USERNAME=emailapikey
SMTP_PASSWORD=
SMTP_FROM=support@harishcriticalcareclasses.com
# CC on registration thank-you, document approve/deny, password mail, event confirmation (comma-separated).
SMTP_CC=dr.harishmm@rocketmail.com,support@harishcriticalcareclasses.com,mohangola47@gmail.com
# Optional BCC (comma-separated).
# SMTP_BCC=

# ICU-ID CONCLAVE event registration (Razorpay charges base + GST)
# EVENT_ICU_D_CONCLAVE_FEE_INR=3200
# EVENT_ICU_D_CONCLAVE_GST_PERCENT=18
# EVENT_ICU_D_CONCLAVE_PROMO_CODES=CONCLAVE100
# EVENT_ICU_D_CONCLAVE_SLUG=icu-id-conclave-2026
# EVENT_ICU_D_CONCLAVE_ACTIVE=true
# Optional PDF filename under uploads/brochures/ (admin upload overrides via DB option)
# EVENT_ICU_D_CONCLAVE_BROCHURE_FILE=

# OTP password reset (React /forgot-password — no email link)
# PASSWORD_RESET_OTP_LENGTH=6
# PASSWORD_RESET_OTP_TTL_MINUTES=10
# PASSWORD_RESET_OTP_RESEND_SECONDS=60

# Legacy PHP public site (optional): only for OLD documents still on the PHP server.
# LEGACY_UPLOAD_BASE_URL=https://harishcriticalcareclasses.com
# Host that serves FastAPI + uploads/registration (REQUIRED on production — e.g. krintixsample.site).
API_PUBLIC_BASE_URL=http://127.0.0.1:8000

# S3 user documents (registration). When S3_BUCKET_NAME is set, uploads go to {S3_USER_PREFIX}/… in the bucket.
# Use AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in .env only — never commit real keys.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=dittoo
# AWS_REGION=ap-south-1
# S3_USER_PREFIX=user
# Presigned URLs for private objects (admin list/detail); max 604800 (7 days).
# S3_PRESIGN_EXPIRES_SEC=86400
# Optional: set to public-read to store a permanent https URL in DB (bucket must allow ACLs / public reads).
# S3_OBJECT_ACL=

# Meta WhatsApp Cloud API (Admin bulk messaging)
# Keep WHATSAPP_API_KEY secret in backend env only.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_BASE=https://graph.facebook.com/v20.0
WHATSAPP_BATCH_SIZE=25
WHATSAPP_SEND_DELAY_MS=100
WHATSAPP_SEND_MAX_RETRIES=1
WHATSAPP_SEND_TIMEOUT_SEC=15
# Optional defaults for Admin → WhatsApp template bulk send
# WHATSAPP_DEFAULT_TEMPLATE_NAME=hello_world
# WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=en_US
# Custom admin-composed message: approved Meta template with {{1}} in body (utility/marketing)
# WHATSAPP_CUSTOM_MESSAGE_TEMPLATE=user_notification
# WHATSAPP_CUSTOM_MESSAGE_TEMPLATE_LANGUAGE=en

# Meta WhatsApp webhook (public GET/POST /webhook — configure in Meta Developer Console)
# WHATSAPP_VERIFY_TOKEN=your-random-verify-string-from-meta-setup
# WHATSAPP_APP_SECRET=your-meta-app-secret-for-x-hub-signature-256
# AUTO_CREATE_WHATSAPP_WEBHOOK_TABLE=true
